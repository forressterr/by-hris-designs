# Re-install when a branch switch changes package.json or package-lock.json.
# Args: $1 = previous HEAD, $2 = new HEAD, $3 = 1 if branch checkout (0 if file).
[ "$3" = "1" ] || exit 0

if [ -n "$(git diff --name-only "$1" "$2" -- package.json package-lock.json)" ]; then
  echo "📦 Dependencies changed — running npm install..."
  npm install
fi
