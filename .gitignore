# Environment — document variables in .env.example, never commit real values
.env*
!.env.example

# Claude Code — local, machine-specific settings. NEVER commit: the permission
# allow-list accumulates approved command strings that can carry secrets (this
# file once leaked a Resend API key). Shared config lives in the committed
# .claude/settings.json instead.
.claude/settings.local.json

