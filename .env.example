# Document each environment variable this project consumes.
# Keep this file checked in; .gitignore ignores all other .env* files.

# Phase 2 — contact API route (src/pages/api/contact.ts). Set all of these in
# Vercel (Production + Preview, tokens marked Sensitive) and in .env.local for
# local dev. The route degrades gracefully: missing Upstash disables the store
# + rate-limiter; a missing Resend key disables email — an enquiry counts as
# received if it was stored OR emailed.
#
# Upstash Redis `by-hris-contact-database` (free tier, GCP europe-west1) —
# rate limiter + 30-day enquiry store. Values: Upstash console → database →
# Details → REST API. (All-access token; swap for an ACL-scoped token later.)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
#
# Resend — server-side email transport (FormSubmit is IP-blocked from Vercel
# datacenters). Key: Resend dashboard → API Keys.
# RESEND_API_KEY=
#
# Phase 4 — Sanity CMS (Projects + Labs). Public `production` dataset → tokenless
# published reads. Set the three NEXT_PUBLIC_* in Vercel (Prod+Preview) and in
# .env.local; the build fetches Sanity at build time.
# NEXT_PUBLIC_SANITY_PROJECT_ID=
# NEXT_PUBLIC_SANITY_DATASET=production
# NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01
#
# Signing secret for the /api/revalidate webhook (generate: openssl rand -hex 32).
# Webhook: Sanity dashboard → API → Webhooks → POST <site>/api/revalidate, on
# create/update/delete, secret = this value, API version 2024-10-01, no projection.
# SANITY_REVALIDATE_SECRET=
